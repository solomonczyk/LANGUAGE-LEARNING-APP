# Language Learning App — Backend Configuration
# Copy to .env and adjust for your local environment
# DO NOT commit real credentials

# Database
DATABASE_URL=postgresql+asyncpg://llapp:llapp_dev@localhost:5432/llapp
DATABASE_ECHO=false

# Application
DEBUG=true
LOG_LEVEL=INFO

# Auth Stub (local development only)
AUTH_STUB_ENABLED=true
AUTH_STUB_USER_ID=00000000-0000-0000-0000-000000000001

# Security (dev-only, not for production)
SECRET_KEY=dev-secret-key-not-for-production

# Mock AI
MOCK_AI_ENABLED=true
MOCK_AI_FIXTURE_MODE=valid
