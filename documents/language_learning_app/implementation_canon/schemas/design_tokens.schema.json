{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "DesignTokens",
  "description": "Design token specification for the language learning app design system",
  "type": "object",
  "required": ["colors", "typography", "spacing", "borderRadius", "elevation"],
  "properties": {
    "colors": {
      "type": "object",
      "required": ["primary", "primaryDark", "secondary", "success", "warning", "error", "info", "background", "surface", "surfaceSecondary", "textPrimary", "textSecondary", "textDisabled", "border", "borderFocus", "borderError", "overlay"],
      "additionalProperties": false
    },
    "typography": {
      "type": "object",
      "required": ["display", "h1", "h2", "h3", "subtitle", "body", "bodySmall", "caption", "button", "buttonSmall", "overline"],
      "additionalProperties": false
    },
    "spacing": {
      "type": "object",
      "required": ["xxs", "xs", "sm", "md", "lg", "xl", "xxl", "xxxl", "huge", "giant"],
      "additionalProperties": false
    },
    "borderRadius": {
      "type": "object",
      "required": ["sm", "md", "lg", "full"],
      "additionalProperties": false
    },
    "elevation": {
      "type": "object",
      "required": ["sm", "md", "lg", "xl"],
      "additionalProperties": false
    }
  }
}
