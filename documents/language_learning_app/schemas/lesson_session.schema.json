{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://language-learning.app/schemas/lesson_session.json",
  "title": "Lesson Session",
  "description": "Record of an actual lesson session execution",
  "type": "object",
  "required": [
    "session_id",
    "lesson_id",
    "learner_id",
    "started_at",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "session_id": {
      "type": "string",
      "format": "uuid"
    },
    "lesson_id": {
      "type": "string",
      "format": "uuid"
    },
    "learner_id": {
      "type": "string"
    },
    "started_at": {
      "type": "string",
      "format": "date-time"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time"
    },
    "status": {
      "type": "string",
      "enum": [
        "in_progress",
        "completed",
        "abandoned"
      ]
    },
    "completion_percentage": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "quiz_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "activities": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "scaffolding_levels_used": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "errors_treated": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}