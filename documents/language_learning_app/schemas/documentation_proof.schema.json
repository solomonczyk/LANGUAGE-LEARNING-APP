{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://language-learning.app/schemas/documentation_proof.json",
  "title": "Documentation Proof",
  "description": "Proof that the documentation task was completed according to specifications",
  "type": "object",
  "required": [
    "task_id",
    "verdict",
    "feature_completed",
    "documentation_only"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "parent_task_id": {
      "type": "string"
    },
    "verdict": {
      "type": "string",
      "enum": [
        "ACCEPTED",
        "REJECTED",
        "PENDING_REVIEW"
      ]
    },
    "feature_completed": {
      "type": "boolean"
    },
    "documentation_only": {
      "type": "boolean"
    },
    "reconciliation_completed": {
      "type": "boolean"
    },
    "canonical_commit_chain_verified": {
      "type": "boolean"
    },
    "requirement_count_delta_explained": {
      "type": "boolean"
    },
    "requirements_lost": {
      "type": "integer",
      "minimum": 0
    },
    "artifact_index_delta_verified": {
      "type": "boolean"
    },
    "forbidden_actions_complete": {
      "type": "boolean"
    },
    "previous_reports_consistent": {
      "type": "boolean"
    },
    "previous_contradictions_resolved": {
      "type": "boolean"
    },
    "documents_created": {
      "type": "boolean"
    },
    "schemas_created": {
      "type": "boolean"
    },
    "examples_created": {
      "type": "boolean"
    },
    "artifact_index_created": {
      "type": "boolean"
    },
    "traceability_complete": {
      "type": "boolean"
    },
    "untraced_requirements": {
      "type": "integer",
      "minimum": 0
    },
    "contradictions_found": {
      "type": "integer",
      "minimum": 0
    },
    "unresolved_blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "current_state": {
      "type": "string"
    },
    "next_allowed_action": {
      "type": "string"
    },
    "application_implementation_allowed": {
      "type": "boolean"
    },
    "production_accepted": {
      "type": "boolean"
    },
    "application_code_changed": {
      "type": "boolean"
    },
    "llm_calls_executed": {
      "type": "boolean"
    },
    "deployment_executed": {
      "type": "boolean"
    },
    "security_requirements_documented": {
      "type": "boolean"
    },
    "anti_cheat_documented": {
      "type": "boolean"
    },
    "prompt_injection_defense_documented": {
      "type": "boolean"
    },
    "contradictions": {
      "type": "object"
    },
    "forbidden_actions": {
      "type": "object"
    },
    "requirements": {
      "type": "object"
    },
    "artifacts": {
      "type": "object"
    },
    "traceability": {
      "type": "object"
    },
    "git": {
      "type": "object",
      "properties": {
        "branch": {
          "type": "string"
        },
        "starting_commit": {
          "type": "string"
        },
        "final_commit": {
          "type": "string"
        },
        "commit_created": {
          "type": "boolean"
        },
        "commit_pushed": {
          "type": "boolean"
        },
        "git_clean": {
          "type": "boolean"
        },
        "head_matches_origin": {
          "type": "boolean"
        }
      }
    },
    "validation": {
      "type": "object"
    },
    "tests": {
      "type": "object",
      "properties": {
        "documentation_tests_passed": {
          "type": "boolean"
        },
        "schema_validation_passed": {
          "type": "boolean"
        },
        "link_validation_passed": {
          "type": "boolean"
        }
      }
    }
  }
}