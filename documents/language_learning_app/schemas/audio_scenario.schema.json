{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://language-learning.app/schemas/audio_scenario.json",
  "title": "Audio Scenario",
  "description": "An audio scenario used as lesson stimulus",
  "type": "object",
  "required": [
    "scenario_id",
    "duration_seconds",
    "transcript"
  ],
  "additionalProperties": false,
  "properties": {
    "scenario_id": {
      "type": "string"
    },
    "duration_seconds": {
      "type": "number",
      "minimum": 5
    },
    "transcript": {
      "type": "string"
    },
    "speaker_count": {
      "type": "integer",
      "minimum": 1
    },
    "cefr_level": {
      "type": "string"
    },
    "vocabulary_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "comprehension_questions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    }
  }
}