{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://language-learning.app/schemas/service_contract.schema.json",
  "title": "Service Contract Schema",
  "description": "Defines the contract for a bounded module/service in the modular monolith",
  "type": "object",
  "required": ["module_name", "responsibility", "owned_entities", "exposed_interfaces", "consumed_interfaces", "forbidden_responsibilities"],
  "properties": {
    "module_name": { "type": "string", "minLength": 1 },
    "responsibility": { "type": "string", "minLength": 1 },
    "owned_entities": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "exposed_interfaces": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["endpoint", "method"],
        "properties": {
          "endpoint": { "type": "string" },
          "method": { "type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"] },
          "request_schema": { "type": "string" },
          "response_schema": { "type": "string" }
        }
      }
    },
    "consumed_interfaces": { "type": "array", "items": { "type": "string" } },
    "forbidden_responsibilities": { "type": "array", "items": { "type": "string" } },
    "state_transitions": { "type": "array", "items": { "type": "string" } },
    "failure_behaviour": { "type": "string" },
    "events_emitted": { "type": "array", "items": { "type": "string" } },
    "observability_signals": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
